# ── MODE ──────────────────────────────────────────────────────
BOT_MODE=paper
PAPER_TRADING_MODE=true
BOT_VERSION=2.3
LOG_LEVEL=INFO

# ── WALLET ────────────────────────────────────────────────────
# POLY_WALLET_TYPE: safe | proxy | gnosis | eoa
# "safe" = Gnosis Safe — mendukung auto-claim
POLYMARKET_PRIVATE_KEY=0xf1959c65187cd3d3e9a177ea03c9c4a0e4f5aadd72486f8c04dbc6c99465fdbf
POLYMARKET_PROXY_WALLET=00x093198a6324ee1971e63f166cd1ac0261453cc0d
POLY_WALLET_TYPE=safe
POLY_CHAIN_ID=137

# ── POLYMARKET API CREDENTIALS ────────────────────────────────
# Generate dengan: python scripts/setup_credentials.py
# Kosong = OK untuk paper mode
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# ── ENDPOINTS ─────────────────────────────────────────────────
CLOB_HOST=https://clob.polymarket.com
RELAYER_URL=https://relayer.polymarket.com
GAMMA_API_URL=https://gamma-api.polymarket.com
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/edWjMoeSK_088tAScr2Jt
POLYGON_GAS_TIP_MULTIPLIER=1.0

# ── WEBSOCKET CONNECTIONS ─────────────────────────────────────
HYPERLIQUID_WS_URL=wss://api.hyperliquid.xyz/ws
HYPERLIQUID_API_KEY=
POLY_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# ── WEBSOCKET RELIABILITY ─────────────────────────────────────
WS_HEARTBEAT_INTERVAL_SEC=5
WS_STALE_THRESHOLD_SEC=15
# Polymarket bisa diam sampai 170s di akhir window — ini normal
POLY_STALE_THRESHOLD_SEC=200
WS_RECONNECT_MAX_RETRY=5
WS_RECONNECT_BASE_DELAY_SEC=2
WS_RECONNECT_MAX_DELAY_SEC=30

# ── CHAINLINK ─────────────────────────────────────────────────
CHAINLINK_CONTRACT_ADDRESS=0xc907E116054Ad103354f2D350FD2514433D57F6F
CHAINLINK_POLL_INTERVAL_SEC=3
# Chainlink delay bisa tembus 170s — naikkan toleransi
CHAINLINK_MAX_AGE_SEC=30
CHAINLINK_MAX_AGE_ENTRY_SEC=180
CHAINLINK_VOLATILITY_SKIP_USD=50.0

# ══════════════════════════════════════════════════════════════
# HEDGE STRATEGY SETTINGS
# ══════════════════════════════════════════════════════════════

# ── STRATEGY SELECTION ────────────────────────────────────────
# DIRECTIONAL = Beli satu sisi (berdasarkan sinyal gap+CVD)
# SMART_HEDGE = Beli dua sisi jika pair_cost < threshold (arbitrage)
# TEMPORAL_HEDGE = Beli sisi termurah satu-satu, track cost kumulatif
HEDGE_STRATEGY=DIRECTIONAL

# Threshold per strategy
DIRECTIONAL_MAX_ODDS=0.40        # Max odds untuk directional bet
SMART_HEDGE_PAIR_MAX=0.95        # Max pair cost untuk arbitrage
TEMPORAL_MAX_SINGLE_ODDS=0.50    # Max odds per sisi untuk temporal
TEMPORAL_MAX_TOTAL_COST=0.95     # Max total cost kedua sisi

# ── HEDGE MODE (Legacy Toggle) ────────────────────────────────
# Beli sisi yang murah (< HEDGE_MODE_ODDS_MAX) di setiap window
# Jika odds < $0.55, beli → menang = $1.00 → profit $0.45 (ROI 82%)
HEDGE_MODE_ENABLED=true
HEDGE_MODE_ODDS_MAX=0.55

# ── GATE CONTROL ──────────────────────────────────────────────
# Gate 3 (liquidity check) dimatikan untuk hedge strategy
# Bot cukup lihat odds < HEDGE_MODE_ODDS_MAX tanpa cek depth
GATE3_ENABLED=false

# ── PAIR COST CONTROL (Legacy) ────────────────────────────────
# Pair cost = up_odds + down_odds. Di market efisien, selalu ≈ $1.00
# Hedge untung jika pair_cost < $1.00 (beli dua sisi, satu pasti $1.00)
# Set ke 1.05 agar masih bisa masuk meskipun ada spread kecil
HEDGE_PAIR_MAX_COST=1.05

# ── ODDS BOUNDARY ─────────────────────────────────────────────
# ODDS_MAX: batas atas odds yang diizinkan untuk entry (non-hedge + Gate 4)
# ODDS_MIN: batas bawah (hindari odds $0.00 yang berarti no liquidity)
ODDS_MIN=0.01
ODDS_MAX=0.55
ODDS_SWEET_SPOT_LOW=0.01
ODDS_SWEET_SPOT_HIGH=0.55

# ── TIMING — MASUK LEBIH AWAL ─────────────────────────────────
# Observasi: odds < 0.20 muncul di T-190 sampai T-130
# Masuk di zona ini sebelum market adjust kembali
GOLDEN_WINDOW_START=240
GOLDEN_WINDOW_END=140

# ── CVD — MINIMAL ─────────────────────────────────────────────
# CVD tidak terlalu relevan untuk hedge strategy
# Tapi tetap aktif sebagai filter noise minimal
CVD_VOLUME_WINDOW_MINUTES=30
CVD_THRESHOLD_PCT=5

# ── VELOCITY — DIMATIKAN ──────────────────────────────────────
# Hedge strategy tidak butuh velocity filter
# Entry berdasarkan odds murah, bukan momentum
VELOCITY_ENABLED=false
VELOCITY_MIN_DELTA=3.0
VELOCITY_WINDOW_SECONDS=2.0

# ── GAP — MINIMAL ─────────────────────────────────────────────
# Gap kecil OK untuk hedge karena kita tidak tebak arah
GAP_THRESHOLD_DEFAULT=15
GAP_THRESHOLD_LOW_VOL=20
GAP_THRESHOLD_HIGH_VOL=10
ATR_LOW_THRESHOLD=50.0
ATR_HIGH_THRESHOLD=150.0
ATR_LOOKBACK_CANDLES=12

# ── SLIPPAGE ──────────────────────────────────────────────────
# Di paper mode slippage tidak relevan
# Di live mode nanti bisa diperketat
SLIPPAGE_THRESHOLD_NORMAL=5.0
SLIPPAGE_THRESHOLD_ELEVATED=7.0
SLIPPAGE_THRESHOLD_HIGH=10.0
SPREAD_MAX_PCT=10.0
MISPRICING_MULTIPLIER=0.15
MISPRICING_MIN_EDGE=0.01

# ── POSITION SIZING ───────────────────────────────────────────
# 1 share per sisi untuk paper testing awal
# Naikkan setelah win rate terbukti > 70%
BASE_SHARES=1.0
MAX_POSITION_USD=5.0

# ── RISK & CIRCUIT BREAKER ────────────────────────────────────
# Longgarkan untuk paper trading — biarkan bot belajar
CIRCUIT_BREAKER_MAX_LOSS=10
COOLDOWN_CIRCUIT_BREAKER_SEC=60
# DATA_STALE cooldown sangat pendek — Polymarket sering diam
COOLDOWN_DATA_STALE_SEC=15
MAX_DAILY_LOSS_USD=0.0
MIN_TRADE_RESERVE=1

# ── AUTO RESUME ───────────────────────────────────────────────
AUTO_RESUME_ENABLED=true
AUTO_RESUME_MAX_ATTEMPTS=10
AUTO_RESUME_CHECK_INTERVAL_SEC=20

# ── SYNC LATENCY ──────────────────────────────────────────────
# Polymarket sync delay bisa sampai 170s — ini normal
# Jangan trigger lockdown karena ini
SYNC_LATENCY_MAX_SEC=180

# ── QUEUE & PROCESSING ────────────────────────────────────────
QUEUE_HL_MAXSIZE=2000
CVD_CALC_INTERVAL_MS=500
MIN_TRADE_SIZE_USD=0.0

# ── SAFETY MONITOR ────────────────────────────────────────────
# Grace period cukup untuk semua feed connect dan subscribe
SAFETY_MONITOR_STARTUP_GRACE_SEC=90

# ── CLAIM / RELAYER ───────────────────────────────────────────
CLAIM_RETRY_MAX=3
CLAIM_RETRY_TIMEOUT_SEC=30
CLAIM_RETRY_INTERVAL_SEC=60

# ── OUTPUT & LOGGING ──────────────────────────────────────────
OUTPUT_DIR=./output
TRADE_LOG_FILE=trade_log.csv
SKIP_LOG_FILE=skip_log.csv
MARKET_SNAPSHOT_FILE=market_snapshot.csv
SESSION_SUMMARY_FILE=session_summary.csv
EVENT_LOG_FILE=event_log.csv
STATE_FILE=engine_state.json
LOG_FLUSH_INTERVAL_SEC=5
LOG_ROTATION_DAYS=30
SNAPSHOT_INTERVAL_SEC=5
STATE_SNAPSHOT_INTERVAL_SEC=5

# ── CLI ────────────────────────────────────────────────────────
CLI_REFRESH_RATE=4
CLI_ORDERBOOK_UPDATE_SEC=2
CLI_TRADE_LOG_ROWS=10