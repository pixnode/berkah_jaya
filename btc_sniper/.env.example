# ── POLYMARKET CLOB SETTINGS ─────────────────────
CLOB_HOST=https://clob.polymarket.com
GAMMA_API_URL=https://gamma-api.polymarket.com
POLYMARKET_PRIVATE_KEY=your_private_key_here
POLY_API_KEY=your_api_key_here
POLY_API_SECRET=your_api_secret_here
POLY_API_PASSPHRASE=your_api_passphrase_here

# WALLET TYPE: 'eoa' or 'safe'
# 'safe' uses gasless relayer (recommended)
POLY_WALLET_TYPE=safe
POLYMARKET_PROXY_WALLET=0xYourSafeProxyAddress

# ── HYPERLIQUID WS SETTINGS ─────────────────────
HL_WS_URL=wss://api.hyperliquid.xyz/ws

# ── CHAINLINK SETTINGS ──────────────────────────
CHAINLINK_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/your_key
CHAINLINK_CONTRACT_ADDRESS=0x13e3F55DC17969544464599D45866171c19b69b2

# ── STRATEGY & RISK ─────────────────────────────
PAPER_TRADING_MODE=true
BASE_SHARES=1.0
MAX_POSITION_USD=50.0

# ── GOLDEN WINDOW (Seconds remaining) ───────────
GOLDEN_WINDOW_START=60
GOLDEN_WINDOW_END=42

# ── GAPS ────────────────────────────────────────
GAP_THRESHOLD_DEFAULT=15.0
GAP_THRESHOLD_LOW_VOL=20.0
GAP_THRESHOLD_HIGH_VOL=10.0

# ── CVD (Cumulative Volume Delta) ───────────────
CVD_THRESHOLD_PCT=0.15
CVD_WINDOW_SECONDS=60

# ── VELOCITY ────────────────────────────────────
VELOCITY_ENABLED=true
VELOCITY_MIN_DELTA=15.0

# ── SLIPPAGE — disesuaikan untuk hedge strategy odds rendah
# Percentage-based for odds >= 0.10
SLIPPAGE_THRESHOLD_NORMAL=5.0
SLIPPAGE_THRESHOLD_ELEVATED=7.0
SLIPPAGE_THRESHOLD_HIGH=10.0
# Absolute-based for odds < 0.10
SLIPPAGE_THRESHOLD_ABS_LOW_ODDS=0.05

# ── HEDGE STRATEGY ──────────────────────────────
# Choices: DIRECTIONAL | SMART_HEDGE | TEMPORAL_HEDGE
HEDGE_STRATEGY=TEMPORAL_HEDGE

# Individual side price cap (Condition 1)
ODDS_MAX=0.30

# SMART HEDGE specific
SMART_HEDGE_PAIR_MAX=0.80

# TEMPORAL HEDGE specific
TEMPORAL_MAX_SINGLE_ODDS=0.40
TEMPORAL_MAX_TOTAL_COST=0.80

# Liquidity Gate (Condition 2)
HEDGE_MIN_DEPTH_USDC=50.0

# ── LOGGING ─────────────────────────────────────
LOG_LEVEL=INFO
LOG_FLUSH_INTERVAL_SEC=10
OUTPUT_DIR=./output
